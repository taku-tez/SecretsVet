# .secretsvet.yaml — SecretsVet project configuration
# Copy this file to .secretsvet.yaml in your repository root.
# All sections are optional.

# Per-rule configuration
rules:
  # Disable rules that are not applicable to your project
  # SV6040:
  #   disabled: true       # Helm-managed Secret warning (if you intentionally use Helm secrets)
  # SV1070:
  #   disabled: true       # Secret immutable:true requirement

  # Override severity for specific rules
  # SV1070:
  #   severity: HIGH       # Treat immutable:true as HIGH instead of LOW
  # SV6040:
  #   severity: LOW        # Downgrade Helm Secret warning

# Detection sensitivity
thresholds:
  # Minimum string length for entropy-based secret detection (default: 20)
  # Increase to reduce false positives on short high-entropy strings
  # entropy_min_length: 24

# Paths to exclude from scanning (supports glob patterns)
ignore:
  paths:
    # - tests/**             # exclude test fixtures
    # - "**/*_test.yaml"     # exclude test manifests
    # - vendor/**            # exclude vendored charts
    # - docs/**              # exclude documentation examples
